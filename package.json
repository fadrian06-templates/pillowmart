{
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@fortawesome/fontawesome-free": "5.8.1",
    "animate.css": "3.7.0",
    "bootstrap": "4.3.1",
    "owl.carousel": "2.3.4",
    "sass": "1.101.0"
  },
  "scripts": {
    "build": "npm run build:sass & npm run build:bootstrap & npm run build:animate.css & npm run build:owl.carousel",
    "build:animate.css": "cp node_modules/animate.css/animate.min.css css/animate.css",
    "build:bootstrap": "cp node_modules/bootstrap/dist/css/bootstrap.min.* css & cp node_modules/bootstrap/dist/js/bootstrap.min.* js",
    "build:fontawesome": "cp node_modules/@fortawesome/fontawesome-free/css/all.min.css css/all.css & cp node_modules/@fortawesome/fontawesome-free/webfonts ./",
    "build:owl.carousel": "cp node_modules/owl.carousel/dist/assets/owl.carousel.min.css css & cp node_modules/owl.carousel/dist/owl.carousel.min.js js",
    "build:sass": "sass -s compressed sass/style.scss css/style.css & npm run build:fontawesome",
    "format": "biome format"
  }
}
